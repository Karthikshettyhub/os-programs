DELIMITER //

CREATE PROCEDURE emp_cursor()
BEGIN
DECLARE id INT;
DECLARE name VARCHAR(20);
DECLARE done INT DEFAULT 0;

DECLARE cur CURSOR FOR
SELECT E_id, E_name FROM Employ;

DECLARE CONTINUE HANDLER FOR NOT FOUND
SET done = 1;

OPEN cur;

read_loop: LOOP

FETCH cur INTO id, name;

IF done = 1 THEN
LEAVE read_loop;
END IF;

SELECT id, name;

END LOOP;

CLOSE cur;

END //

DELIMITER ;

CALL emp_cursor();
